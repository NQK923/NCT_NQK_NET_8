    "@angular/forms": "^22.0.2",
    "@angular/material": "^18.2.10",
    "@angular/platform-browser": "^21.2.14",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^21.2.14",
    "bootstrap": "^5.3.3",
    "jest-editor-support": "^32.0.0-beta.1",
    "jquery": "^3.7.1",
    "popper.js": "^1.16.1",
